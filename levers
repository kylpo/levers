# Output helpers
# ---------------------------------------------------------------------------


def _die(msg: str, code: int = 2) -> int:
    typer.echo(f"error: {msg}", err=True)
    return code


def _warn(msg: str) -> None:
    typer.echo(f"warning: {msg}", err=True)


