# `__file__` is the symlink path when installed via install.sh; resolve() follows
# it to the real repo dir so we can find schema.yml + templates/ alongside.
REPO_ROOT = Path(__file__).resolve().parent
SCHEMA_PATH = REPO_ROOT / "schema.yml"
TEMPLATES_DIR = REPO_ROOT / "templates"

DEFAULT_FILENAME = ".levers.yml"

# ---------------------------------------------------------------------------
# YAML loader (shared)
# ---------------------------------------------------------------------------

_yaml = YAML(typ="rt")
_yaml.preserve_quotes = True


def load_yaml(path: Path) -> dict:
    """Load a YAML file. Returns {} for empty files."""
    with path.open() as f:
        data = _yaml.load(f)
    return data or {}


def dump_yaml(data: dict, path: Path) -> None:
    """Write a YAML file via ruamel.yaml (preserves comments on roundtrip)."""
    with path.open("w") as f:
        _yaml.dump(data, f)


# ---------------------------------------------------------------------------
# Schema
# ---------------------------------------------------------------------------


class Role(str, Enum):
    single = "single"
    root = "root"
    package = "package"


class Schema:
    """Wrapper around schema.yml exposing lookups used by every command."""

    def __init__(self, path: Path = SCHEMA_PATH) -> None:
        raw = load_yaml(path)
        self.categories: dict = raw["categories"]
        self.levers: dict = raw["levers"]

    def keys(self) -> list[str]:
        return list(self.levers.keys())

    def values_for(self, key: str) -> list[str]:
        return list(self.levers[key]["values"])

    def scope(self, key: str) -> str:
        return self.levers[key]["scope"]

    def category(self, key: str) -> str:
        return self.levers[key]["category"]

    def strictness(self, key: str) -> Optional[list[str]]:
        return self.levers[key].get("strictness")

    def required_for(self, role: Role) -> set[str]:
        """Keys a .levers.yml of this role must declare."""
        if role is Role.single:
            return {k for k, v in self.levers.items() if v["scope"] in ("repo", "package")}
        if role is Role.root:
            return {k for k, v in self.levers.items() if v["scope"] == "repo"}
        return {k for k, v in self.levers.items() if v["scope"] == "package"}

    def forbidden_for(self, role: Role) -> set[str]:
        """Keys a .levers.yml of this role must NOT declare."""
        if role is Role.single:
            return set()
        if role is Role.root:
            return {k for k, v in self.levers.items() if v["scope"] == "package"}
        return {k for k, v in self.levers.items() if v["scope"] == "repo"}

    def category_label(self, cat_id: str) -> str:
        return self.categories[cat_id]["label"]

    def keys_by_category(self) -> dict[str, list[str]]:
        """Return {category_id: [key, ...]} preserving schema order."""
        out: dict[str, list[str]] = {cat: [] for cat in self.categories}
        for key, cfg in self.levers.items():
            out[cfg["category"]].append(key)
        return out


def _load_schema() -> Schema:
    if not SCHEMA_PATH.exists():
        raise typer.Exit(_die(f"schema.yml not found at {SCHEMA_PATH}"))
    return Schema()


# ---------------------------------------------------------------------------
# .levers.yml file discovery
# ---------------------------------------------------------------------------


def resolve_levers_path(at: Optional[Path]) -> Path:
    """Resolve --at to a concrete .levers.yml file path.

    Rules:
    - If `at` is a file ending in .yml/.yaml, use it directly.
    - If `at` is a directory, look for `<at>/.levers.yml`.
    - If `at` is None, default to `./.levers.yml`.
    """
    target = at if at is not None else Path.cwd()
    if target.is_file():
        return target
    if target.is_dir():
        return target / DEFAULT_FILENAME
    # Non-existent path — treat as a file path the user means
    return target


