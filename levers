def _find_repo_root(start: Path) -> Optional[Path]:
    """Walk up from `start` looking for a .git dir/file. Returns None if not found."""
    for d in [start, *start.parents]:
        if (d / ".git").exists():
            return d
    return None


# ---------------------------------------------------------------------------
# resolve
# ---------------------------------------------------------------------------


class ResolveFormat(str, Enum):
    yaml = "yaml"
    json = "json"


class ResolveError(Exception):
    """Raised by resolution helpers when a path can't be resolved."""


def _find_package_levers(start: Path, repo_root: Path) -> Optional[Path]:
    """Walk up from `start` (exclusive of repo_root) looking for .levers.yml."""
    d = start if start.is_dir() else start.parent
    d = d.resolve()
    root = repo_root.resolve()
    while d != root and d != d.parent:
        candidate = d / DEFAULT_FILENAME
        if candidate.is_file():
            return candidate
        d = d.parent
    return None


def _abs_or_absolute(p: Path) -> Path:
    """Best-effort absolute path that works for non-existent inputs."""
    return p.resolve() if p.exists() else p.absolute()


def _resolve_one(target: Path, repo_root_override: Optional[Path]) -> dict:
    """Compute the effective .levers.yml view for a single path.

    Returns: {"data": merged_dict, "root_file": Path, "pkg_file": Path | None}
    """
    if repo_root_override is not None:
        repo_root = repo_root_override.resolve()
    else:
        found = _find_repo_root(_abs_or_absolute(target))
        if found is None:
            raise ResolveError(
                f"could not find repo root for {target} (no .git found). "
                f"Pass --repo-root to override."
            )
        repo_root = found

    root_file = repo_root / DEFAULT_FILENAME
    if not root_file.is_file():
        raise ResolveError(
            f"no .levers.yml at repo root ({repo_root}) — run `levers init` to author one"
        )

    abs_target = _abs_or_absolute(target)
    try:
        abs_target.relative_to(repo_root)
    except ValueError:
        raise ResolveError(f"{target} is outside repo root {repo_root}")

    root_data = load_yaml(root_file)
    pkg_file = _find_package_levers(abs_target, repo_root)
    if pkg_file is not None and pkg_file != root_file:
        pkg_data = load_yaml(pkg_file)
        merged: dict = {**root_data, **pkg_data}
    else:
        pkg_file = None
        merged = dict(root_data)

    return {"data": merged, "root_file": root_file, "pkg_file": pkg_file}


def _narrow(data: dict, keys: list[str]) -> dict:
    """Filter `data` to `keys`, preserving the order in `keys`."""
    return {k: data[k] for k in keys if k in data}


def _emit(data: dict, fmt: ResolveFormat, comment_lines: list[str]) -> None:
    """Emit a resolved view as YAML (with comment header) or JSON."""
    if fmt is ResolveFormat.json:
        typer.echo(json.dumps(data, indent=2, sort_keys=True))
        return
    for line in comment_lines:
        typer.echo(line)
    buf = io.StringIO()
    plain = YAML(typ="safe")
    plain.default_flow_style = False
    plain.dump(data, buf)
    typer.echo(buf.getvalue().rstrip("\n"))


def _parse_csv_keys(value: Optional[str]) -> list[str]:
    if not value:
        return []
    return [k.strip() for k in value.split(",") if k.strip()]


@app.command()
def resolve(
    paths: list[Path] = typer.Argument(
        ...,
        help="One or more paths inside the repo. With --merge-strictest, multiple paths are folded; otherwise pass exactly one.",
    ),
    get: Optional[str] = typer.Option(
        None,
        "--get",
        help="Print just the value for a single key (no YAML fences).",
    ),
    keys: Optional[str] = typer.Option(
        None,
        "--keys",
        help="Comma-separated list of keys to narrow the output to.",
    ),
    fmt: ResolveFormat = typer.Option(
        ResolveFormat.yaml,
        "--format",
        help="Output format.",
    ),
    repo_root: Optional[Path] = typer.Option(
        None,
        "--repo-root",
        help="Override the repo root (defaults to walking up to .git).",
    ),
    merge_strictest: bool = typer.Option(
        False,
        "--merge-strictest",
        help="Resolve each path independently, then fold across using strictness order.",
    ),
) -> None:
    """Compute the effective .levers.yml view at one or more paths."""
    schema = _load_schema()

    key_filter = _parse_csv_keys(keys)
    for k in key_filter:
        if k not in schema.levers:
            raise typer.Exit(_die(f"unknown lever key: {k}"))
    if get is not None and get not in schema.levers:
        raise typer.Exit(_die(f"unknown lever key: {get}"))
    if get is not None and merge_strictest:
        raise typer.Exit(_die("--get cannot be combined with --merge-strictest"))
    if get is not None and key_filter:
        raise typer.Exit(_die("--get cannot be combined with --keys"))

    # ---- --merge-strictest mode ----
    if merge_strictest:
        if len(paths) < 1:
            raise typer.Exit(_die("--merge-strictest requires at least one path"))
        resolved: list[dict] = []
        for p in paths:
            try:
                resolved.append(_resolve_one(p, repo_root))
            except ResolveError as exc:
                raise typer.Exit(_die(str(exc), code=1))

        target_keys = key_filter if key_filter else schema.keys()
        merged: dict = {}
        for k in target_keys:
            vals = [r["data"].get(k) for r in resolved if k in r["data"]]
            if not vals:
                continue
            if all(v == vals[0] for v in vals):
                merged[k] = vals[0]
                continue
            order = schema.strictness(k)
            if order is None:
                raise typer.Exit(
                    _die(
                        f"lever {k!r} is not strictness-mergeable across packages — split the change or pick per-package",
                        code=1,
                    )
                )
            winner = next((v for v in order if v in vals), None)
            if winner is None:
                raise typer.Exit(_die(f"unexpected: no winner for {k} among {vals}"))
            merged[k] = winner

        keys_label = ",".join(key_filter) if key_filter else "(all)"
        header = [
            "---",
            f"# Synthesized by `levers resolve --merge-strictest` across {len(paths)} path(s)",
            f"# Root: {resolved[0]['root_file']}",
            f"# Keys: {keys_label}",
        ]
        _emit(merged, fmt, header)
        if fmt is ResolveFormat.yaml:
            typer.echo("---")
        return

    # ---- Single-path mode ----
    if len(paths) != 1:
        raise typer.Exit(
            _die(f"exactly one path required (got {len(paths)}) unless using --merge-strictest")
        )
    try:
        r = _resolve_one(paths[0], repo_root)
    except ResolveError as exc:
        raise typer.Exit(_die(str(exc), code=1))

    data = r["data"]

    if get is not None:
        if get not in data:
            raise typer.Exit(
                _die(f"{get} is not declared in the effective view for {paths[0]}", code=1)
            )
        typer.echo(data[get])
        return

    out = _narrow(data, key_filter) if key_filter else data
    pkg_line = (
        f"# Package: {r['pkg_file']}" if r["pkg_file"] is not None
        else "# Package: (none — single-repo or no nearest-ancestor package file)"
    )
    keys_label = ",".join(key_filter) if key_filter else "(all)"
    header = [
        "---",
        f"# Synthesized by `levers resolve` for {paths[0]}",
        f"# Root: {r['root_file']}",
        pkg_line,
        f"# Keys: {keys_label}",
    ]
    _emit(out, fmt, header)
    if fmt is ResolveFormat.yaml:
        typer.echo("---")


@app.command("add-package")
def add_package(
    path: Path = typer.Argument(..., help="Package directory to scaffold a .levers.yml in."),
    force: bool = typer.Option(
        False,
        "--force",
        help="Overwrite an existing .levers.yml in the package directory.",
    ),
) -> None:
    """Scaffold a package-scoped .levers.yml inside a monorepo."""
    pkg_dir = path
    if not pkg_dir.exists():
        raise typer.Exit(_die(f"{pkg_dir} does not exist"))
    if not pkg_dir.is_dir():
        raise typer.Exit(_die(f"{pkg_dir} is not a directory"))

    repo_root = _find_repo_root(pkg_dir.resolve())
    if repo_root is None:
        raise typer.Exit(
            _die(f"{pkg_dir} is not inside a git repository — cannot detect monorepo root")
        )

    root_levers = repo_root / DEFAULT_FILENAME
    if not root_levers.exists():
        raise typer.Exit(
            _die(
                f"no root .levers.yml at {root_levers} — run "
                f"`levers init --role root --at {repo_root}` first"
            )
        )

    if pkg_dir.resolve() == repo_root:
        raise typer.Exit(
            _die("refusing to add-package at the repo root — that's the root file", code=1)
        )

    target = pkg_dir / DEFAULT_FILENAME
    _write_template(Role.package, target, force)
    typer.echo(f"ok: wrote {target}")


# ---------------------------------------------------------------------------
# audit — drift detection
# ---------------------------------------------------------------------------

_SEMVER_RE = re.compile(r"^\d+\.\d+\.\d+(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$")
_AUDIT_SKIP_DIRS = {".git", "node_modules", ".build", "DerivedData", ".venv"}


def _git(repo: Path, *args: str) -> Optional[str]:
    """Run `git -C repo args...`. Returns stripped stdout, or None on error."""
    try:
        result = subprocess.run(
            ["git", "-C", str(repo), *args],
            capture_output=True,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        return None
    if result.returncode != 0:
        return None
    return result.stdout.strip()


def _tag_matches_package(pkg_basename: str, tag: str) -> bool:
    """True iff tag looks like '<pkg>-v...' or '<pkg>/v...'."""
    return tag.startswith(f"{pkg_basename}-v") or tag.startswith(f"{pkg_basename}/v")


def _workflows_dir(repo_root: Path) -> Optional[Path]:
    d = repo_root / ".github" / "workflows"
    return d if d.is_dir() else None


def _workflows_have_push_or_pr(workflows_dir: Path) -> bool:
    pattern = re.compile(r"^\s*(push|pull_request)\s*:", re.MULTILINE)
    for f in workflows_dir.rglob("*.y*ml"):
        try:
            if pattern.search(f.read_text()):
                return True
        except OSError:
            continue
    return False


def _workflows_mention(workflows_dir: Path, *needles: str) -> bool:
    for f in workflows_dir.rglob("*.y*ml"):
        try:
            content = f.read_text()
        except OSError:
            continue
        if any(n in content for n in needles):
            return True
    return False


def _audit_root(repo_root: Path) -> list[tuple[str, str]]:
    """Drift warnings for the root .levers.yml. Returns (context, message) tuples."""
    warnings: list[tuple[str, str]] = []
    root_file = repo_root / DEFAULT_FILENAME
    if not root_file.is_file():
        raise typer.Exit(_die(f"{root_file} not found"))

    try:
        data = load_yaml(root_file)
    except Exception as exc:
        raise typer.Exit(_die(f"failed to parse {root_file}: {exc}"))

    # team_mode: solo vs >1 authors in last 90 days
    if data.get("team_mode") == "solo":
        out = _git(repo_root, "log", "--since=90 days ago", "--format=%ae")
        if out:
            authors = {line for line in out.splitlines() if line}
            if len(authors) > 1:
                warnings.append((
                    "root",
                    f"declared `team_mode: solo`, observed {len(authors)} unique "
                    "authors in the last 90 days — flip to small_team/large_team, or "
                    "explain in DECISIONS.",
                ))

    # ci_gate: none vs push/pull_request workflows
    if data.get("ci_gate") == "none":
        wf = _workflows_dir(repo_root)
        if wf is not None and _workflows_have_push_or_pr(wf):
            warnings.append((
                "root",
                "declared `ci_gate: none`, observed push/pull_request workflows "
                "under .github/workflows — if CI actually gates merges, flip ci_gate "
                "(or override per-package).",
            ))

    return warnings


def _audit_package(repo_root: Path, pkg_dir: Path) -> list[tuple[str, str]]:
    """Drift warnings for a single package .levers.yml."""
    warnings: list[tuple[str, str]] = []
    pkg_file = pkg_dir / DEFAULT_FILENAME
    if not pkg_file.is_file():
        raise typer.Exit(_die(f"{pkg_file} not found"))

    try:
        data = load_yaml(pkg_file)
    except Exception as exc:
        raise typer.Exit(_die(f"failed to parse {pkg_file}: {exc}"))

    try:
        rel = str(pkg_dir.resolve().relative_to(repo_root.resolve()))
    except ValueError:
        rel = str(pkg_dir)
    basename = pkg_dir.name

    # Tag-based checks (lifecycle_stage + versioning)
    tags_out = _git(
        repo_root,
        "for-each-ref",
        "--sort=creatordate",
        "--format=%(creatordate:unix) %(refname:short)",
        "refs/tags/*",
    )
    pkg_tags: list[tuple[int, str]] = []
    if tags_out:
        for line in tags_out.splitlines():
            parts = line.split(maxsplit=1)
            if len(parts) != 2:
                continue
            try:
                ts = int(parts[0])
            except ValueError:
                continue
            name = parts[1]
            if _tag_matches_package(basename, name):
                pkg_tags.append((ts, name))

    # lifecycle_stage vs old v1+ tag
    lifecycle = data.get("lifecycle_stage")
    if lifecycle in ("pre_launch", "prototype"):
        now = int(time.time())
        for ts, name in pkg_tags:
            ver = name.rsplit("v", 1)[-1]
            major = ver.split(".", 1)[0]
            if major.isdigit() and int(major) >= 1:
                age_days = (now - ts) // 86400
                if age_days > 30:
                    warnings.append((
                        rel,
                        f"declared `lifecycle_stage: {lifecycle}`, observed `{name}` "
                        f"({age_days}d old) — is {rel} actually post_launch?",
                    ))
                    break

    # versioning: semver vs latest non-semver-shaped tag
    if data.get("versioning") == "semver" and pkg_tags:
        latest = pkg_tags[-1][1]
        tail = latest.rsplit("v", 1)[-1]
        if not _SEMVER_RE.match(tail):
            warnings.append((
                rel,
                f"declared `versioning: semver`, latest package tag '{latest}' "
                "is not semver-shaped.",
            ))

    # ci_gate (package override) vs workflows referencing this package
    if data.get("ci_gate") == "none":
        wf = _workflows_dir(repo_root)
        if (
            wf is not None
            and _workflows_have_push_or_pr(wf)
            and _workflows_mention(wf, rel, f"{basename}/")
        ):
            warnings.append((
                rel,
                f"declared `ci_gate: none`, observed a workflow referencing "
                f"'{rel}' or '{basename}/' — if CI gates merges for this package, "
                "update the override.",
            ))

    # Internal contradiction: continuous releases on a milestone cadence
    if data.get("release_model") == "continuous" and data.get("release_cadence") == "milestone":
        warnings.append((
            rel,
            "declared `release_model: continuous` but `release_cadence: milestone` "
            "— these contradict.",
        ))

    return warnings


def _discover_packages(repo_root: Path) -> list[Path]:
    """Find every nested .levers.yml under repo_root, excluding the root file."""
    out: list[Path] = []
    root_abs = repo_root.resolve()

    def walk(d: Path) -> None:
        if d.name in _AUDIT_SKIP_DIRS:
            return
        for entry in d.iterdir():
            if entry.is_dir():
                walk(entry)
            elif entry.name == DEFAULT_FILENAME and entry.parent.resolve() != root_abs:
                out.append(entry.parent)

    walk(repo_root)
    return sorted(out)


class AuditMode(str, Enum):
    all = "all"
    root = "root"
    package = "package"


@app.command()
def audit(
    path: Optional[Path] = typer.Argument(
        None,
        help="Repo root (default mode) or a specific path (with --root/--package). Defaults to cwd.",
    ),
    root_only: bool = typer.Option(
        False,
        "--root",
        help="Audit only the root .levers.yml.",
    ),
    package: Optional[Path] = typer.Option(
        None,
        "--package",
        help="Audit only this package directory.",
    ),
    strict: bool = typer.Option(
        False,
        "--strict",
        help="Exit non-zero if any drift warnings are emitted (intended for CI).",
    ),
) -> None:
    """Detect drift between declared lever values and observable repo signals.

    Default behavior: audit the root file plus every nested package file.
    Use --root or --package to restrict the scope. Output is informational;
    exit code is 0 even on drift unless --strict is set.
    """
    if root_only and package is not None:
        raise typer.Exit(_die("--root and --package are mutually exclusive"))

    target = path if path is not None else Path.cwd()
    target = target.resolve()
    warnings: list[tuple[str, str]] = []

    if package is not None:
        pkg_dir = package.resolve()
        repo_root = _find_repo_root(pkg_dir)
        if repo_root is None:
            raise typer.Exit(
                _die(f"{pkg_dir} is not inside a git repository")
            )
        warnings.extend(_audit_package(repo_root, pkg_dir))
    elif root_only:
        warnings.extend(_audit_root(target))
    else:
        warnings.extend(_audit_root(target))
        for pkg_dir in _discover_packages(target):
            warnings.extend(_audit_package(target, pkg_dir))

    for ctx, msg in warnings:
        typer.echo(f"⚠ drift ({ctx}): {msg}")

    if not warnings:
        typer.echo("levers audit: no drift detected")
        return

    typer.echo(f"levers audit: {len(warnings)} drift warning(s)")
    if strict:
        raise typer.Exit(1)


if __name__ == "__main__":
    app()
