def _template_path(role: Role) -> Path:
    return TEMPLATES_DIR / f"{role.value}.yml"


def _write_template(role: Role, target: Path, force: bool) -> None:
    """Copy a template to `target`, refusing to overwrite without --force."""
    src = _template_path(role)
    if not src.exists():
        raise typer.Exit(_die(f"template not found: {src}"))

    if target.exists() and not force:
        raise typer.Exit(
            _die(f"{target} already exists — pass --force to overwrite", code=1)
        )

    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_bytes(src.read_bytes())


@app.command()
def init(
    role: Role = typer.Option(
        Role.single,
        "--role",
        help="Project shape. `single` for a single-repo project; `root` for a monorepo's root file.",
    ),
    at: Optional[Path] = typer.Option(
        None,
        "--at",
        help="Directory to write .levers.yml into. Defaults to cwd.",
    ),
    force: bool = typer.Option(
        False,
        "--force",
        help="Overwrite an existing .levers.yml.",
    ),
    no_interactive: bool = typer.Option(
        False,
        "--no-interactive",
        help="Skip the interactive editor and write the template as-is.",
    ),
) -> None:
    """Create a new .levers.yml from a template.

    By default, opens an interactive editor seeded with the template's
    default values: ↑/↓ select, ←/→ cycle values, ENTER save, ESC cancel.
    Pass --no-interactive (or pipe stdin) to write the template verbatim.
    """
    if role is Role.package:
        raise typer.Exit(
            _die(
                "use `levers add-package <path>` to scaffold a package file in a monorepo",
                code=2,
            )
        )

    at_dir = at if at is not None else Path.cwd()
    if at_dir.exists() and not at_dir.is_dir():
        raise typer.Exit(_die(f"{at_dir} is not a directory"))

    target = at_dir / DEFAULT_FILENAME
    src = _template_path(role)
    if not src.exists():
        raise typer.Exit(_die(f"template not found: {src}"))
    if target.exists() and not force:
        raise typer.Exit(
            _die(f"{target} already exists — pass --force to overwrite", code=1)
        )

    if no_interactive or not sys.stdin.isatty():
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_bytes(src.read_bytes())
        typer.echo(f"ok: wrote {target} (role={role.value})")
        return

    schema = _load_schema()
    data = load_yaml(src)
    changes = _tui_edit(
        title=f"levers init — {target}  (role={role.value})",
        schema=schema,
        role=role,
        initial=data,
    )
    if changes is None:
        typer.echo("cancelled: no changes written", err=True)
        return

    for k, _, new in changes:
        data[k] = new
    target.parent.mkdir(parents=True, exist_ok=True)
    dump_yaml(data, target)

    if not changes:
        typer.echo(f"ok: wrote {target} (role={role.value})")
        return
    header = (
        f"ok: wrote {target} (role={role.value}, "
        f"{len(changes)} tweak{'s' if len(changes) != 1 else ''} from template)"
    )
    _print_change_summary(target, changes, header)


# ---------------------------------------------------------------------------
# merge-strictest — cross-package strictness fold (rare, for automation)
# ---------------------------------------------------------------------------


@app.command("merge-strictest")
def merge_strictest(
    paths: list[Path] = typer.Argument(
        ...,
        help="Paths spanning multiple packages. Each lever folds to its strictest value across the paths.",
    ),
    keys: Optional[str] = typer.Option(
        None,
        "--keys",
        help="Comma-separated list of keys to narrow the output to.",
    ),
    fmt: ResolveFormat = typer.Option(
        ResolveFormat.yaml,
        "--format",
        help="Output format.",
    ),
    repo_root: Optional[Path] = typer.Option(
        None,
        "--repo-root",
        help="Override the repo root (defaults to walking up to .git).",
    ),
) -> None:
    """Fold the effective view across multiple paths using strictness ordering.

    For unattended automation that must produce a single decision over a change
    set spanning multiple packages (e.g., one auto-merge verdict for a PR
    touching apps/mobile and packages/shared). Prefer per-package splitting
    when possible — this is the cross-cutting fallback. Errors on levers that
    have no strictness order if their values diverge across paths.
    """
    schema = _load_schema()

    key_filter = _parse_csv_keys(keys)
    for k in key_filter:
        if k not in schema.levers:
            raise typer.Exit(_die(f"unknown lever key: {k}"))

    if len(paths) < 1:
        raise typer.Exit(_die("merge-strictest requires at least one path"))

    resolved: list[dict] = []
    for p in paths:
        try:
            resolved.append(_resolve_one(p, repo_root))
        except ResolveError as exc:
            raise typer.Exit(_die(str(exc), code=1))

    target_keys = key_filter if key_filter else schema.keys()
    merged: dict = {}
    for k in target_keys:
        vals = [r["data"].get(k) for r in resolved if k in r["data"]]
        if not vals:
            continue
        if all(v == vals[0] for v in vals):
            merged[k] = vals[0]
            continue
        order = schema.strictness(k)
        if order is None:
            raise typer.Exit(
                _die(
                    f"lever {k!r} is not strictness-mergeable across packages — split the change or pick per-package",
                    code=1,
                )
            )
        winner = next((v for v in order if v in vals), None)
        if winner is None:
            raise typer.Exit(_die(f"unexpected: no winner for {k} among {vals}"))
        merged[k] = winner

    keys_label = ",".join(key_filter) if key_filter else "(all)"
    header = [
        "---",
        f"# Synthesized by `levers merge-strictest` across {len(paths)} path(s)",
        f"# Root: {resolved[0]['root_file']}",
        f"# Keys: {keys_label}",
    ]
    _emit(merged, fmt, header)
    if fmt is ResolveFormat.yaml:
        typer.echo("---")


