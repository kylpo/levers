@app.command("set")
def set_(
    key: Optional[str] = typer.Argument(None, help="Lever key to write. Omit (with value) to open the interactive editor."),
    value: Optional[str] = typer.Argument(None, help="New value (must be in the key's enum)."),
    at: Optional[Path] = typer.Option(
        None,
        "--at",
        help="Path to .levers.yml (or directory containing one). Defaults to ./.levers.yml.",
    ),
) -> None:
    """Set lever values, preserving existing comments and layout.

    Two forms:
      levers set <key> <value>   non-interactive, single key
      levers set                 interactive editor over the whole file
    """
    schema = _load_schema()
    target = resolve_levers_path(at)
    if not target.exists():
        raise typer.Exit(_die(f"{target} not found — run `levers init` first"))

    # Interactive mode: no positional args.
    if key is None and value is None:
        if not sys.stdin.isatty():
            raise typer.Exit(
                _die("`levers set` requires <key> <value> when stdin isn't a tty")
            )
        data = load_yaml(target)
        role = _infer_role(data, schema)
        changes = _tui_edit(
            title=f"levers set — {target}  (role={role.value})",
            schema=schema,
            role=role,
            initial=data,
        )
        if changes is None:
            typer.echo("cancelled: no changes written", err=True)
            return
        if not changes:
            typer.echo(f"ok: {target} (no changes)")
            return
        for k, _, new in changes:
            data[k] = new
        dump_yaml(data, target)
        header = (
            f"ok: {target} — {len(changes)} change{'s' if len(changes) != 1 else ''}"
        )
        _print_change_summary(target, changes, header)
        return

    # Non-interactive single-key form requires both args.
    if key is None or value is None:
        raise typer.Exit(
            _die("provide both <key> and <value>, or neither (interactive editor)")
        )

    if key not in schema.levers:
        raise typer.Exit(_die(f"unknown key: {key}"))

    allowed = schema.values_for(key)
    if value not in allowed:
        raise typer.Exit(
            _die(f"invalid value {value!r} for {key} — allowed: {', '.join(allowed)}")
        )

    data = load_yaml(target)
    previous = data.get(key)
    data[key] = value
    dump_yaml(data, target)

    if previous is None:
        typer.echo(f"ok: {target} {key} = {value} (added)")
    elif previous == value:
        typer.echo(f"ok: {target} {key} = {value} (unchanged)")
    else:
        typer.echo(f"ok: {target} {key}: {previous} → {value}")


