@app.command()
def get(
    key: Optional[str] = typer.Argument(
        None,
        help="Lever key to read. Omit to print all effective keys.",
    ),
    at: Optional[Path] = typer.Option(
        None,
        "--at",
        help="Path inside the repo (file or directory). Defaults to cwd.",
    ),
    keys: Optional[str] = typer.Option(
        None,
        "--keys",
        help="Comma-separated list of keys to narrow the output to.",
    ),
    fmt: ResolveFormat = typer.Option(
        ResolveFormat.yaml,
        "--format",
        help="Output format (used when emitting multiple keys).",
    ),
    repo_root: Optional[Path] = typer.Option(
        None,
        "--repo-root",
        help="Override the repo root (defaults to walking up to .git).",
    ),
) -> None:
    """Read effective lever values at a path (root + nearest-ancestor package, merged).

    With a positional <key>, prints just the raw value (no fences). Without,
    prints the full merged view (YAML with provenance header by default, or
    JSON via --format json). Use --keys to narrow to a list.
    """
    schema = _load_schema()

    if key is not None and keys is not None:
        raise typer.Exit(_die("--keys cannot be combined with a positional key"))
    if key is not None and key not in schema.levers:
        raise typer.Exit(_die(f"unknown lever key: {key}"))

    key_filter = _parse_csv_keys(keys)
    for k in key_filter:
        if k not in schema.levers:
            raise typer.Exit(_die(f"unknown lever key: {k}"))

    target = at if at is not None else Path.cwd()
    try:
        r = _resolve_one(target, repo_root)
    except ResolveError as exc:
        raise typer.Exit(_die(str(exc), code=1))

    data = r["data"]

    if key is not None:
        if key not in data:
            raise typer.Exit(
                _die(f"{key} is not declared in the effective view for {target}", code=1)
            )
        typer.echo(data[key])
        return

    out = _narrow(data, key_filter) if key_filter else data
    pkg_line = (
        f"# Package: {r['pkg_file']}" if r["pkg_file"] is not None
        else "# Package: (none — single-repo or no nearest-ancestor package file)"
    )
    keys_label = ",".join(key_filter) if key_filter else "(all)"
    header = [
        "---",
        f"# Synthesized by `levers get` for {target}",
        f"# Root: {r['root_file']}",
        pkg_line,
        f"# Keys: {keys_label}",
    ]
    _emit(out, fmt, header)
    if fmt is ResolveFormat.yaml:
        typer.echo("---")


