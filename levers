@app.command()
def get(
    key: str = typer.Argument(..., help="Lever key to read."),
    at: Optional[Path] = typer.Option(
        None,
        "--at",
        help="Path to .levers.yml (or directory containing one). Defaults to ./.levers.yml.",
    ),
) -> None:
    """Print the value of a single lever key from a .levers.yml file."""
    schema = _load_schema()
    if key not in schema.levers:
        raise typer.Exit(_die(f"unknown key: {key}"))

    target = resolve_levers_path(at)
    if not target.exists():
        raise typer.Exit(_die(f"{target} not found"))

    data = load_yaml(target)
    if key not in data:
        raise typer.Exit(_die(f"{key} not declared in {target}", code=1))

    typer.echo(data[key])


# ---------------------------------------------------------------------------
# set
# ---------------------------------------------------------------------------


@app.command("set")
def set_(
    key: str = typer.Argument(..., help="Lever key to write."),
    value: str = typer.Argument(..., help="New value (must be in the key's enum)."),
    at: Optional[Path] = typer.Option(
        None,
        "--at",
        help="Path to .levers.yml (or directory containing one). Defaults to ./.levers.yml.",
    ),
) -> None:
    """Set a single lever value, preserving existing comments and layout."""
    schema = _load_schema()
    if key not in schema.levers:
        raise typer.Exit(_die(f"unknown key: {key}"))

    allowed = schema.values_for(key)
    if value not in allowed:
        raise typer.Exit(
            _die(f"invalid value {value!r} for {key} — allowed: {', '.join(allowed)}")
        )

    target = resolve_levers_path(at)
    if not target.exists():
        raise typer.Exit(
            _die(f"{target} not found — run `levers init` first")
        )

    data = load_yaml(target)
    previous = data.get(key)
    data[key] = value
    dump_yaml(data, target)

    if previous is None:
        typer.echo(f"ok: {target} {key} = {value} (added)")
    elif previous == value:
        typer.echo(f"ok: {target} {key} = {value} (unchanged)")
    else:
        typer.echo(f"ok: {target} {key}: {previous} → {value}")


